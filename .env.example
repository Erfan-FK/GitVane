# ----------------------------------------------------------------------------
# GitVane environment variables
# Copy this file to `.env.local` and fill in the values.
# ----------------------------------------------------------------------------

# Anthropic (Claude) — used for the prose-synthesis generation step.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model used for generation (optional, has a sensible default).
ANTHROPIC_MODEL=claude-sonnet-4-5

# GitHub server token used for anonymous repo analysis (avoids the 60 req/hr
# unauthenticated rate limit). Create a fine-grained, read-only PAT with
# public-repo read access: https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=

# Supabase — auth + analysis history + cache.
# Project URL and publishable (anon) key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key is SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for OAuth redirects). Defaults to http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: outbound proxy for reaching the GitHub API / Anthropic. Node's
# global fetch does not honor the system proxy, so set this if you're behind a
# corporate proxy or a local VPN client (e.g. http://127.0.0.1:10808).
# HTTPS_PROXY=
